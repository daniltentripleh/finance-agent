# Recommended for Vercel deployments
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional model override for the Agent SDK worker
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional prebuilt Vercel Sandbox snapshot containing the Claude runtime.
# If omitted, the route installs Claude Code + the Agent SDK inside a fresh sandbox.
# VERCEL_SANDBOX_SNAPSHOT_ID=snap_xxxxx

# Supabase-backed chat attachment storage
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_ATTACHMENTS_BUCKET=chat-attachments
